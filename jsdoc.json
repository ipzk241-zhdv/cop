{
    "source": {
        "include": ["src"],
        "includePattern": ".+\\.js(doc|x)?$",
        "excludePattern": "(^|\\/|\\\\)_"
    },
    "plugins": ["plugins/markdown"],
    "opts": {
        "encoding": "utf8",
        "destination": "./docs/gen",
        "recurse": true,
        "verbose": true,
        "internal": true,
        "private": true
    },
    "templates": {
        "cleverLinks": true,
        "monospaceLinks": true
    }
}
